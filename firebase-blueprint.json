{
  "entities": {
    "Prompt": {
      "title": "Prompt",
      "description": "An AI prompt submitted by a user or created by an admin",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "promptText": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "isFeatured": { "type": "boolean" },
        "isTrending": { "type": "boolean" },
        "slug": { "type": "string" },
        "viewCount": { "type": "number" },
        "copyCount": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "description", "promptText", "category", "status", "createdAt", "updatedAt"]
    },
    "SavedPrompt": {
      "title": "SavedPrompt",
      "description": "A prompt saved by a user",
      "type": "object",
      "properties": {
        "savedAt": { "type": "number" }
      },
      "required": ["savedAt"]
    }
  },
  "firestore": {
    "/prompts/{promptId}": {
      "schema": { "$ref": "#/entities/Prompt" },
      "description": "Stores all prompts (both pending and approved)"
    },
    "/users/{userId}/savedPrompts/{promptId}": {
      "schema": { "$ref": "#/entities/SavedPrompt" },
      "description": "User's saved prompts"
    }
  }
}
